{
    "name": "fahdi/fahad-ai-shopping-assistant-for-woocommerce",
    "description": "AI-powered WooCommerce shopping assistant",
    "type": "wordpress-plugin",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "brain/monkey": "^2.6",
        "mockery/mockery": "^1.6",
        "squizlabs/php_codesniffer": "^3.9",
        "wp-coding-standards/wpcs": "^3.1",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
    },
    "autoload-dev": {
        "psr-4": {
            "FahadAi\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "phpcs": "phpcs",
        "phpcbf": "phpcbf",
        "test": "phpunit --testsuite unit",
        "test:coverage": [
            "phpunit --testsuite unit --coverage-clover build/clover.xml --coverage-filter includes",
            "php tests/check-coverage.php build/clover.xml 100"
        ]
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
